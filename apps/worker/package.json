{
  "name": "@news-aggregator/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "briefing:preview": "tsx src/index.ts briefing:preview",
    "briefing:audio": "tsx src/index.ts briefing:audio",
    "briefing:deliver": "tsx src/index.ts briefing:deliver",
    "elevenlabs:probe": "tsx src/index.ts elevenlabs:probe",
    "audio:serve": "tsx src/index.ts audio:serve",
    "sonos:probe": "tsx src/index.ts sonos:probe",
    "sonos:play-briefing": "tsx src/index.ts sonos:play-briefing",
