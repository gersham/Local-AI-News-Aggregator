{
  "name": "news-aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.19.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "dev": "pnpm --filter @news-aggregator/web dev",
    "dev:web": "pnpm --filter @news-aggregator/web dev",
    "dev:worker": "pnpm --filter @news-aggregator/worker dev",
    "build": "pnpm --recursive --if-present build",
    "test": "pnpm --recursive --if-present test",
    "test:unit": "pnpm --recursive --if-present test",
    "test:e2e": "pnpm exec playwright test",
    "lint": "pnpm exec biome check .",
    "format": "pnpm exec biome format --write .",
    "verify:tools": "tsx scripts/verify-tools.ts",
    "verify:services": "tsx scripts/verify-services.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@playwright/test": "1.59.1",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.0",
    "mongodb": "^6.21.0",
    "mongodb-memory-server": "^11.0.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
